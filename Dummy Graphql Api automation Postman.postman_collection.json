      "name": "Login Api",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();\r",
              "\r",
              "const items = json.data.getParentCategoriesWithChildren.items;\r",
              "\r",
              "//\r",
              "// 1. STATUS CODE\r",
              "//\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "//\r",
              "// 2. RESPONSE TIME\r",
              "//\r",
              "pm.test(\"Response time is under 1500ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(1500);\r",
              "});\r",
              "\r",
              "//\r",
              "// 3. EXACT COUNT CHECK (12 CATEGORIES)\r",
              "//\r",
              "pm.test(\"Should return exactly 12 categories\", function () {\r",
              "    pm.expect(items.length).to.equal(12);\r",
              "});\r",
              "\r",
              "//\r",
              "// 4. EXACT ORDER CHECK (BASED ON YOUR RESPONSE)\r",
              "//\r",
              "const expectedOrder = [\r",
              "    \"Sleep\",\r",
              "    \"8D\",\r",
              "    \"Focus\",\r",
              "    \"Meditation\",\r",
              "    \"Relaxation\",\r",
              "    \"ASMR\",\r",
              "    \"Healing Voices\",\r",
              "    \"Instruments\",\r",
              "    \"Frequencies\",\r",
              "    \"Ambient/Lofi\",\r",
              "    \"Sleep Hypnosis\",\r",
              "    \"Tinnitus\"\r",
              "];\r",
              "\r",
              "pm.test(\"Category order should match API response order\", function () {\r",
              "    const actualOrder = items.map(i => i.categoryName);\r",
              "    pm.expect(actualOrder).to.deep.equal(expectedOrder);\r",
              "});\r",
              "\r",
              "//\r",
              "// 5. NO DUPLICATES CHECK\r",
              "//\r",
              "pm.test(\"No duplicate category names\", function () {\r",
              "    const names = items.map(i => i.categoryName);\r",
              "    const unique = new Set(names);\r",
              "    pm.expect(unique.size).to.equal(names.length);\r",
              "});\r",
              "\r",
              "//\r",
              "// 6. ID VALIDATION\r",
              "//\r",
              "pm.test(\"Each category must have valid id\", function () {\r",
              "    items.forEach(item => {\r",
              "        pm.expect(item.id).to.exist;\r",
              "        pm.expect(item.id).to.be.a(\"string\");\r",
              "    });\r",
              "});\r",
              "\r",
              "//\r",
              "// 7. ICON VALIDATION (FIXED - icons CAN BE NULL)\r",
              "//\r",
              "pm.test(\"Icons validation (allow null)\", function () {\r",
              "    items.forEach(item => {\r",
              "\r",
              "        if (item.icons !== null) {\r",
              "            pm.expect(item.icons.dark.active).to.not.be.empty;\r",
              "            pm.expect(item.icons.dark.inactive).to.not.be.empty;\r",
              "        } else {\r",
              "            // allow null icons but ensure category still valid\r",
              "            pm.expect(item.categoryName).to.exist;\r",
              "        }\r",
              "\r",
              "    });\r",
              "});\r",
