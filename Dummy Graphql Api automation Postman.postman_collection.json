    {
      "name": "GetTrAacks",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const response = pm.response.json();\r",
              "\r",
              "pm.test(\"Response should not contain GraphQL errors\", function () {\r",
              "    pm.expect(response.errors).to.be.undefined;\r",
              "});\r",
              "\r",
              "pm.test(\"Response time should be below 3000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);\r",
              "});\r",
              "\r",
              "pm.test(\"Response should contain getTracks object\", function () {\r",
              "    pm.expect(response.data).to.have.property(\"getTracks\");\r",
              "});\r",
              "\r",
              "pm.test(\"Tracks array should exist\", function () {\r",
              "    pm.expect(response.data.getTracks).to.have.property(\"tracks\");\r",
              "    pm.expect(response.data.getTracks.tracks).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "const tracks = response.data.getTracks.tracks;\r",
              "\r",
              "pm.test(\"Tracks array should not be empty\", function () {\r",
              "    pm.expect(tracks.length).to.be.greaterThan(0);\r",
              "});\r",
              "\r",
              "tracks.forEach((track, index) => {\r",
              "\r",
              "    pm.test(`Track ${index + 1} should have title`, function () {\r",
              "        pm.expect(track.title).to.not.be.null;\r",
              "        pm.expect(track.title).to.not.equal(\"\");\r",
              "        pm.expect(track.title).to.be.a(\"string\");\r",
              "    });\r",
              "\r",
              "    pm.test(`Track ${index + 1} should have storageKeys`, function () {\r",
              "        pm.expect(track.storageKeys).to.be.an(\"object\");\r",
              "    });\r",
              "\r",
              "    pm.test(`Track ${index + 1} should have azure object`, function () {\r",
              "        pm.expect(track.storageKeys.azure).to.be.an(\"object\");\r",
              "    });\r",
              "\r",
              "    pm.test(`Track ${index + 1} should have freeTrackUrl`, function () {\r",
              "        pm.expect(track.storageKeys.azure.freeTrackUrl).to.be.a(\"string\");\r",
              "        pm.expect(track.storageKeys.azure.freeTrackUrl).to.not.equal(\"\");\r",
              "    });\r",
              "\r",
              "    pm.test(`Track ${index + 1} should have valid freeTrackUrl`, function () {\r",
              "        pm.expect(\r",
              "            track.storageKeys.azure.freeTrackUrl\r",
              "        ).to.match(/^https?:\\/\\/.+/);\r",
              "    });\r",
              "\r",
              "    pm.test(`Track ${index + 1} should have image url`, function () {\r",
              "        pm.expect(track.storageKeys.azure.image).to.be.a(\"string\");\r",
              "        pm.expect(track.storageKeys.azure.image).to.not.equal(\"\");\r",
              "    });\r",
              "\r",
              "    pm.test(`Track ${index + 1} should have valid image url`, function () {\r",
              "        pm.expect(\r",
              "            track.storageKeys.azure.image\r",
              "        ).to.match(/^https?:\\/\\/.+/);\r",
              "    });\r",
              "\r",
              "});\r",
              "\r",
              "console.log(\"Total Tracks:\", tracks.length);\r",
              "console.log(\"Tracks Response:\", tracks);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
